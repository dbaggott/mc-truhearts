{
	"schemaVersion": 1,
	"id": "truheart",
	"version": "${version}",
	"name": "TruHeart",
	"description": "Shows real (un-rounded) HP for you, your target, and the damage your attacks deal.",
	"authors": [
		"Dan Baggott"
	],
	"contact": {
		"sources": "https://github.com/dbaggott/mc-truheart"
	},
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"main": [
			"io.dnbg.minecraft.truheart.TruHeart"
		],
		"client": [
			"io.dnbg.minecraft.truheart.client.TruHeartClient"
		]
	},
	"mixins": [
		"truheart.mixins.json",
		{
			"config": "truheart.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
